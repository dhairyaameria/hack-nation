# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# LLM & research (required)
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
TAVILY_API_KEY=tvly-...

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# Comma-separated extra CORS origins for the API (Vercel URL after deploy)
CORS_ORIGINS=

# Supabase Storage bucket for inbound pitch decks (create in dashboard)
# Used by POST /application/submit + inbound Perplexity rerank
# DECKS_BUCKET=decks

# Frontend flags
NEXT_PUBLIC_USE_FIXTURES=true
NEXT_PUBLIC_USE_NETWORK_FIXTURE=true

# Optional — cut first if behind schedule
ELEVENLABS_API_KEY=
DATABRICKS_HOST=
DATABRICKS_TOKEN=
